# Real backend URL — central payment portal
NEXT_PUBLIC_BACKEND_URL=https://api.accommodationstiet.shop
ADMIN_API_KEY=generate_a_strong_random_key_here

# Admin rotating key configuration (optional)
# Keep ADMIN_PORTAL_PASSWORD/ADMIN_API_KEY as emergency fallback password.
ADMIN_TIME_KEY_ENABLED=false
ADMIN_TIME_KEY_SEED=replace_with_long_random_seed
ADMIN_TIME_KEY_WINDOW_MINUTES=10
ADMIN_TIME_KEY_MODULUS=1000000
ADMIN_TIME_KEY_DAYDATE_MOD=97
